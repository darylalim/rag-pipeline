# Copy to .env and fill in. ANTHROPIC_API_KEY and VOYAGE_API_KEY are both required.
# Embedding calls Voyage AI (at ingest and query); generation calls Claude.

ANTHROPIC_API_KEY=your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key

# --- Optional overrides (defaults shown) ---
# CHAT_MODEL=claude-haiku-4-5   # e.g. claude-opus-4-8 for higher quality
# MAX_TOKENS=1024
# EMBEDDING_MODEL=voyage-4-lite   # e.g. voyage-3-large / voyage-code-3
# RETRIEVAL_K=4                   # chunks kept after reranking
# FETCH_K=20                      # candidates fetched before reranking
# RERANK_MODEL=rerank-2.5-lite    # Voyage reranker; e.g. rerank-2.5 for higher quality
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# DATA_DIR=./data
# PERSIST_DIR=./chroma_db
# COLLECTION_NAME=rag_docs

# --- Optional: LangSmith tracing (observability) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=rag-pipeline
