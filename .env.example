# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required.
# Ingest/embedding runs locally (no key needed); the query step calls Claude.

ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Optional overrides (defaults shown) ---
# CHAT_MODEL=claude-opus-4-8
# MAX_TOKENS=1024
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RETRIEVAL_K=4
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# DATA_DIR=./data
# PERSIST_DIR=./chroma_db
# COLLECTION_NAME=rag_docs

# --- Optional: LangSmith tracing (observability) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=rag-pipeline
