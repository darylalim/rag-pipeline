# Copy to .env and fill in. ANTHROPIC_API_KEY, VOYAGE_API_KEY and MONGODB_URI are
# all required. Voyage AI embeds (at ingest and query) and reranks (at query);
# Claude generates; MongoDB Atlas Vector Search stores and searches the vectors.

ANTHROPIC_API_KEY=your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key
# Atlas connection string, e.g. mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/
# Percent-encode special characters in the password. Plain pymongo resolves
# mongodb+srv:// (dnspython is a hard dependency) — no [srv] extra needed.
MONGODB_URI=your-atlas-connection-string

# --- Optional overrides (defaults shown) ---
# CHAT_MODEL=claude-haiku-4-5   # e.g. claude-opus-4-8 for higher quality
# MAX_TOKENS=1024
# EMBEDDING_MODEL=voyage-4-lite   # e.g. voyage-3-large / voyage-code-3
# EMBEDDING_DIMENSIONS=1024       # width of the embedding vectors; pins the index
# RETRIEVAL_K=4                   # chunks kept after reranking
# FETCH_K=20                      # candidates fetched before reranking
# RERANK_MODEL=rerank-2.5-lite    # Voyage reranker; e.g. rerank-2.5 for higher quality
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# DATA_DIR=./data
# MONGODB_DB=rag_db               # Atlas database holding the collection
# COLLECTION_NAME=rag_docs        # Atlas collection holding the vectors
# VECTOR_INDEX_NAME=vector_index  # Atlas Vector Search index over the collection
# ATLAS_SIMILARITY=cosine         # cosine | euclidean | dotProduct
# MONGODB_TIMEOUT_MS=10000        # serverSelectionTimeoutMS for the Mongo client

# --- Optional: LangSmith tracing (observability) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=rag-pipeline
